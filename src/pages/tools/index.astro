---
import BlogLayout from "../../layouts/BlogLayout.astro";
import { withBase } from "../../utils/url";
import { siteData } from "../../data/site";

const title = `Diagnostics | ${siteData.hero.name}`;
const description =
  "Free, practical diagnostics for AI product leaders and enterprise software teams. No sign-up required.";

const tools = [
  {
    href: withBase("/tools/ai-approach-finder"),
    eyebrow: "Decision Tool",
    title: "AI Approach Finder",
    description:
      "Answer eight questions to get a scored recommendation across two layers: the right AI brain (rules, ML, deep learning, GenAI) and the right deployment architecture (RAG or Agents).",
    cta: "Find your approach →",
    meta: "8 questions · 2 layers · Free",
  },
  {
    href: withBase("/tools/ai-readiness-checklist"),
    eyebrow: "Assessment",
    title: "AI Readiness Checklist",
    description:
      "Work through 28 questions across five dimensions — business priority, data readiness, architecture maturity, governance, and delivery capability — before scoping any AI engagement.",
    cta: "Run the checklist →",
    meta: "28 questions · 5 dimensions · Free",
  },
  {
    href: withBase("/tools/data-readiness"),
    eyebrow: "Assessment",
    title: "Data Readiness Checklist",
    description:
      "Work through 27 questions across five dimensions — accessibility, quality, ownership, compliance, and freshness — before starting any AI project.",
    cta: "Run the checklist →",
    meta: "27 questions · 5 dimensions · Free",
  },
];
---

<BlogLayout {title} {description}>
  <div class="blog-page shell">
    <header class="blog-page__header reveal" style="--delay: 0ms">
      <p class="eyebrow">Free resources</p>
      <h1 class="section-title">Diagnostics</h1>
      <p class="blog-page__description">{description}</p>
    </header>

    <div class="tools-grid">
      {tools.map((tool) => (
        <a href={tool.href} class="tool-card">
          <div class="tool-card__body">
            <p class="eyebrow tool-card__eyebrow">{tool.eyebrow}</p>
            <h2 class="tool-card__title">{tool.title}</h2>
            <p class="tool-card__description">{tool.description}</p>
            <div class="tool-card__footer">
              <span class="tool-card__meta">{tool.meta}</span>
              <span class="tool-card__cta">{tool.cta}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BlogLayout>
