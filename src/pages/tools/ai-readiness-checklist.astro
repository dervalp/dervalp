---
import BlogLayout from "../../layouts/BlogLayout.astro";
import AIReadinessChecklist from "../../components/AIReadinessChecklist.astro";
import { withBase } from "../../utils/url";
import { siteData } from "../../data/site";

const title = "AI Readiness Checklist | Pierre Derval";
const description =
  "28 questions across five dimensions — business priority, data readiness, architecture maturity, governance, and delivery capability. Know before you build.";

const toolUrl = Astro.site
  ? new URL(withBase("/tools/ai-readiness-checklist"), Astro.site).toString()
  : withBase("/tools/ai-readiness-checklist");

const shareText =
  "Are you really ready to start an AI project? This free checklist covers business priority, data readiness, architecture, governance & delivery across 28 questions.";

const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(toolUrl)}`;
const twitterShareUrl  = `https://twitter.com/intent/tweet?url=${encodeURIComponent(toolUrl)}&text=${encodeURIComponent(shareText)}`;
---

<BlogLayout {title} {description}>
  <Fragment slot="head">
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={toolUrl} />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
  </Fragment>

  <div class="tool-page shell">

    <!-- Page header -->
    <header class="tool-page__header reveal" style="--delay: 0ms">
      <a href={withBase("/tools")} class="eyebrow tool-page__back">← Tools</a>
      <h1 class="tool-page__title">AI Readiness Checklist</h1>
      <p class="tool-page__description">
        A red flag in any one dimension can stall or sink an entire initiative.
        Work through each section before scoping your next AI engagement.
      </p>

      <!-- Share row -->
      <div class="tool-page__share">
        <span class="eyebrow">Share</span>
        <a href={linkedinShareUrl} class="icon-link-button"
           target="_blank" rel="noreferrer" aria-label="Share on LinkedIn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a href={twitterShareUrl} class="icon-link-button"
           target="_blank" rel="noreferrer" aria-label="Share on X (Twitter)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
    </header>

    <!-- Checklist -->
    <div class="tool-page__checklist">
      <AIReadinessChecklist />
    </div>

    <!-- Bottom share nudge -->
    <footer class="tool-page__footer">
      <p class="eyebrow">Found this useful?</p>
      <p class="tool-page__footer-text">
        Share it with your team or anyone evaluating an AI initiative.
      </p>
      <div class="tool-page__share">
        <a href={linkedinShareUrl} class="icon-link-button"
           target="_blank" rel="noreferrer" aria-label="Share on LinkedIn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a href={twitterShareUrl} class="icon-link-button"
           target="_blank" rel="noreferrer" aria-label="Share on X (Twitter)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
    </footer>

  </div>
</BlogLayout>
