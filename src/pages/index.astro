---
import CapabilityCard from "../components/CapabilityCard.astro";
import ContactPanel from "../components/ContactPanel.astro";
import CredibilityItem from "../components/CredibilityItem.astro";
import HeaderNav from "../components/HeaderNav.astro";
import IconLink from "../components/IconLink.astro";
import SectionHeading from "../components/SectionHeading.astro";
import TransformationCard from "../components/TransformationCard.astro";
import { siteData } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/url";

const resumeHref = withBase(siteData.socials.resumePath);
const heroBackgroundHref = withBase("/hero-background-test.png");
const credibilityBackgroundHref = withBase("/proven-enterprise-background.png");
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT?.trim() ?? "";

const diagnostics = [
  {
    href: withBase("/tools/ai-business-case-scorecard"),
    eyebrow: "Scorecard",
    title: "AI Business Case Scorecard",
    description: "Nine questions across five dimensions to score your AI business case before it reaches leadership.",
    date: "Apr 2026",
  },
  {
    href: withBase("/tools/ai-approach-finder"),
    eyebrow: "Decision Tool",
    title: "AI Approach Finder",
    description: "Eight questions to find the right AI approach for your use case — rules, ML, GenAI, RAG, or Agents.",
    date: "Mar 2025",
  },
  {
    href: withBase("/tools/ai-readiness-checklist"),
    eyebrow: "Assessment",
    title: "AI Readiness Checklist",
    description: "28 questions across five dimensions to assess whether your team and organisation are ready to ship AI.",
    date: "Feb 2025",
  },
  {
    href: withBase("/tools/data-readiness"),
    eyebrow: "Assessment",
    title: "Data Readiness Checklist",
    description: "27 questions across five dimensions to evaluate data quality, governance, and accessibility before any AI project.",
    date: "Jan 2025",
  },
];
---

<BaseLayout>
  <HeaderNav
    ctaHref={withBase("/contact")}
    ctaLabel={siteData.hero.primaryCtaLabel}
    githubUrl={siteData.socials.githubUrl}
    linkedinUrl={siteData.socials.linkedinUrl}
    name={siteData.hero.name}
    sections={siteData.navigation}
  />

  <main id="main-content">
    <section class="section section--hero">
      <div aria-hidden="true" class="hero__backdrop">
        <img
          alt=""
          class="hero__background-image"
          decoding="async"
          loading="eager"
          src={heroBackgroundHref}
        />
      </div>

      <div class="shell">
        <div class="hero hero__layout reveal">
          <div class="hero__content">
            <h1 class="hero__headline">{siteData.hero.headline}</h1>

            <div class="hero__copy">
              {siteData.hero.supportingText.map((paragraph) => <p>{paragraph}</p>)}
            </div>

            <ul class="hero__focus-list" aria-label="Areas of focus">
              {siteData.hero.focusAreas.map((focusArea) => <li>{focusArea}</li>)}
            </ul>
          </div>

          <aside class="hero__actions-panel" aria-label="Primary actions">
            <IconLink
              external={true}
              href={siteData.socials.linkedinUrl}
              icon="linkedin"
              kind="button-secondary"
              label={siteData.hero.secondaryCtaLabel}
            />
            <IconLink
              external={true}
              href={siteData.socials.githubUrl}
              icon="github"
              kind="button-secondary"
              label={siteData.hero.quaternaryCtaLabel}
            />
            <IconLink href={resumeHref} icon="download" kind="button-secondary" label={siteData.hero.tertiaryCtaLabel} />
          </aside>
        </div>
      </div>
    </section>

    <section class="shell section section-band section-band--muted" data-section id="diagnostics">
      <div class="reveal">
        <p class="eyebrow">Diagnostics</p>
        <h2 class="section-title mt-5">Practical tools for AI decisions</h2>
      </div>
      <div class="diagnostics-grid" role="list">
        {diagnostics.map((d, i) => (
          <div class="diagnostic-card reveal" style={`--delay: ${i * 80}ms`} role="listitem">
            <div class="diagnostic-card__body">
              <p class="diagnostic-card__eyebrow eyebrow">{d.eyebrow}</p>
              <h3 class="diagnostic-card__title">{d.title}</h3>
              <p class="diagnostic-card__desc">{d.description}</p>
            </div>
            <div class="diagnostic-card__footer">
              <div class="diagnostic-card__meta">
                <span class="diagnostic-card__date-label">Date</span>
                <span class="diagnostic-card__date">{d.date}</span>
              </div>
              <hr class="diagnostic-card__rule" />
              <a href={d.href} class="button-primary diagnostic-card__cta">Start →</a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="shell section section-band section-band--muted" data-section id="point-of-view">
      <div class="point-of-view__layout grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-16">
        <div class="point-of-view__intro reveal">
          <p class="eyebrow">Point of view</p>
          <h2 class="section-title mt-5 max-w-lg">
            {siteData.pointOfView.titleLines.map((line) => <span class="block">{line}</span>)}
          </h2>

          <div class="point-of-view__partners point-of-view__partners--headline" aria-label={siteData.pointOfView.workWithLabel}>
            <p class="eyebrow">{siteData.pointOfView.workWithLabel}</p>

            <ul class="point-of-view__partner-list" aria-label={siteData.pointOfView.workWithLabel}>
              {
                siteData.pointOfView.workWith.map((item) => (
                  <li class={`point-of-view__partner point-of-view__partner--${item.slug}`}>
                    <img
                      alt={item.name}
                      decoding="async"
                      loading="lazy"
                      src={withBase(item.logoPath)}
                    />
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <div class="point-of-view__body reveal" style="--delay: 80ms;">
          <div class="point-of-view__copy text-base leading-8 text-ink-600 sm:text-lg">
            {siteData.pointOfView.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            <p class="point-of-view-note">{siteData.pointOfView.closing}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="shell section" data-section id="capabilities">
      <div class="reveal">
        <SectionHeading
          description={siteData.capabilities.description}
          eyebrow="Focus"
          title={siteData.capabilities.title}
        />
      </div>

      <div class="capability-groups">
        {
          siteData.capabilities.groups.map((group, groupIndex) => (
            <section class="capability-group reveal" style={`--delay: ${80 + groupIndex * 70}ms;`}>
              <p class="eyebrow capability-group__label">{group.label}</p>

              <div class="capability-group__grid">
                {
                  group.items.map((item) => (
                    <div class="h-full">
                      <CapabilityCard
                        description={item.description}
                        title={item.title}
                      />
                    </div>
                  ))
                }
              </div>
            </section>
          ))
        }
      </div>
    </section>

    <section class="shell section section-band section-band--strong" data-section id="transformations">
      <div class="reveal">
        <SectionHeading
          description={siteData.transformations.description}
          eyebrow="Work"
          title={siteData.transformations.title}
        />
      </div>

      <div class="transformation-grid">
        {
          siteData.transformations.items.map((item, index) => (
            <div class="reveal h-full" style={`--delay: ${90 + index * 60}ms;`}>
              <TransformationCard description={item.description} eyebrow={item.eyebrow} title={item.title} />
            </div>
          ))
        }
      </div>
    </section>

    <section class="section section-band section-band--muted section--credibility-art" data-section id="credibility">
      <div aria-hidden="true" class="credibility-strip__backdrop">
        <img
          alt=""
          class="credibility-strip__background-image"
          decoding="async"
          loading="lazy"
          src={credibilityBackgroundHref}
        />
      </div>

      <div class="shell">
        <div class="credibility-strip reveal">
          <div class="max-w-2xl">
            <p class="eyebrow">Experience / credibility</p>
            <h2 class="section-title mt-5">{siteData.credibility.title}</h2>
            {siteData.credibility.description && (
              <p class="mt-5 text-base leading-8 text-ink-600 sm:text-lg">
                {siteData.credibility.description}
              </p>
            )}
          </div>

          <div class="credibility-strip__grid">
            {
              siteData.credibility.items.map((item) => (
                <CredibilityItem
                  company={item.company}
                  logoAlt={item.logoAlt}
                  logoPath={item.logoPath}
                  relevance={item.relevance}
                  slug={item.slug}
                />
              ))
            }
          </div>

          {siteData.credibility.note && (
            <p class="credibility-strip__note">
              {siteData.credibility.note}
            </p>
          )}
        </div>
      </div>
    </section>

    <section class="shell section section-band section-band--strong" data-section id="contact">
      <div class="reveal">
        <ContactPanel
          description={siteData.contact.description}
          directDescription={siteData.contact.directDescription}
          directMessage={siteData.contact.directMessage}
          directTitle={siteData.contact.directTitle}
          endpoint={contactEndpoint}
          errorMessage={siteData.contact.errorMessage}
          formDescription={siteData.contact.formDescription}
          formTitle={siteData.contact.formTitle}
          githubUrl={siteData.socials.githubUrl}
          linkedinUrl={siteData.socials.linkedinUrl}
          privacyNote={siteData.contact.privacyNote}
          resumeHref={resumeHref}
          submitLabel={siteData.contact.submitLabel}
          successMessage={siteData.contact.successMessage}
          title={siteData.contact.title}
          unavailableMessage={siteData.contact.unavailableMessage}
        />
      </div>
    </section>
  </main>

</BaseLayout>
