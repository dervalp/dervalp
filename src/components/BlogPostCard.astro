---
import type { CollectionEntry } from "astro:content";
import { slugify, formatDate } from "../utils/blog";
import { withBase } from "../utils/url";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, excerpt, author, publishDate, category, tags, image, imageAlt } = post.data;

const postHref = withBase(`/blog/${post.slug}`);
const categoryHref = withBase(`/blog/category/${slugify(category)}`);
---

<article class="blog-card">
  {image && (
    <div class="blog-card__image-wrap">
      <img
        src={image}
        alt={imageAlt ?? ""}
        loading="lazy"
        decoding="async"
        class="blog-card__image"
      />
    </div>
  )}
  <div class="blog-card__body">
    <a href={categoryHref} class="eyebrow blog-card__category">{category}</a>
    <h2 class="blog-card__title">
      <a href={postHref}>{title}</a>
    </h2>
    <div class="blog-card__meta">
      <span class="blog-card__author">{author}</span>
      <time datetime={publishDate.toISOString()} class="blog-card__date">
        {formatDate(publishDate)}
      </time>
    </div>
    <p class="blog-card__excerpt">{excerpt}</p>
    {tags.length > 0 && (
      <div class="blog-card__tags">
        {tags.map((tag) => (
          <a href={withBase(`/blog/tag/${slugify(tag)}`)} class="blog-tag">
            {tag}
          </a>
        ))}
      </div>
    )}
    <span class="blog-card__read-more" aria-hidden="true">Read more →</span>
  </div>
</article>
