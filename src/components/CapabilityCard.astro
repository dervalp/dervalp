---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<article class="capability-block">
  <div class="capability-block__content">
    {eyebrow && <p class="eyebrow capability-block__eyebrow">{eyebrow}</p>}
    <h3 class="text-[1.65rem] font-semibold tracking-[-0.05em] text-ink-950 sm:text-[1.9rem]">{title}</h3>
    <p class="mt-5 max-w-xl text-base leading-8 text-ink-600">{description}</p>
  </div>
</article>
