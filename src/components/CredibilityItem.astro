---
import { withBase } from "../utils/url";

interface Props {
  company: string;
  relevance?: string | string[];
  logoAlt: string;
  logoPath: string;
  slug: string;
}

const { relevance, logoAlt, logoPath, slug } = Astro.props;
const resolvedLogoPath = withBase(logoPath);
const relevanceLines = Array.isArray(relevance) ? relevance : relevance ? [relevance] : [];
const hasRelevance = relevanceLines.length > 0;
---

<article class:list={["credibility-item", !hasRelevance && "credibility-item--logo-only"]}>
  <div class={`credibility-logo credibility-logo--${slug}`}>
    <img
      src={resolvedLogoPath}
      alt={logoAlt}
      loading="lazy"
      decoding="async"
    />
  </div>
  {
    hasRelevance && (
      <div class="credibility-item__meta">
        {relevanceLines.map((line) => (
          <p class="text-sm leading-7 text-ink-600 sm:text-base">{line}</p>
        ))}
      </div>
    )
  }
</article>
