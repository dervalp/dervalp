var apsState = {
  step:1,dimStep:0,
  profile:{projectName:'',approach:'',domain:'',teamSize:'',timeline:'',budget:''},
  scores:{data:[0,0,0],model:[0,0,0],architecture:[0,0,0],governance:[0,0,0],team:[0,0,0],evaluation:[0,0,0]}
