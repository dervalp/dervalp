    var taskRows=apsPLAN.tasks.map(function(t){
      var dimObj=DIMENSIONS.find(function(d){return d.id===t.dim});
      return[PHASE_META[t.phase].label,dimObj?dimObj.label:t.dim,t.title,t.desc,t.role,t.size,t.priority,'Open',''];
    });
    var ws3=XLSX.utils.aoa_to_sheet([taskHeader].concat(taskRows));
    ws3['!cols']=[{wch:13},{wch:22},{wch:46},{wch:62},{wch:22},{wch:7},{wch:11},{wch:8},{wch:30}];
    XLSX.utils.book_append_sheet(wb,ws3,'Task List');

    var riskHeader=['Dimension','Risk','Impact','Likelihood','Mitigation Action','Owner','Status'];
    var riskRows=apsPLAN.risks.map(function(r){
      var dimObj=DIMENSIONS.find(function(d){return d.id===r.dim});
      return[dimObj?dimObj.label:r.dim,r.title,r.impact,r.likelihood,r.mitigation,'PM / Tech Lead','Open'];
    });
    var ws4=XLSX.utils.aoa_to_sheet([riskHeader].concat(riskRows));
    ws4['!cols']=[{wch:20},{wch:52},{wch:9},{wch:12},{wch:70},{wch:18},{wch:9}];
    XLSX.utils.book_append_sheet(wb,ws4,'Risk Register');

    var filename='AI-Scope-'+pn.replace(/\s+/g,'-')+'.xlsx';
    XLSX.writeFile(wb,filename);
  }

  if(window.XLSX){doExport();return}
  var s=document.createElement('script');
  s.src='https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
  s.onload=doExport;
  document.head.appendChild(s);
};

// ═══════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════
// Expose internal state for the bundled export script
window.apsGetState=function(){return apsState};
window.apsGetPlan=function(){return apsPLAN};
window.apsGetDimScore=apsDimScore;
window.apsGetDimLevelLabel=apsDimLevelLabel;
window.apsGetDIMENSIONS=function(){return DIMENSIONS};

apsRenderStep1();
})();
</script>

<script>
import { showExportDialog } from "../utils/exportDialog";

(window as any).apsExportExcelWithDialog = async () => {
  const result = await showExportDialog("AI Project Scoper", "Excel");
  if (!result) return;
  const state = (window as any).apsGetState();
  const plan = (window as any).apsGetPlan();
  const DIMS = (window as any).apsGetDIMENSIONS();
  const scores: Record<string, number> = {};
  DIMS.forEach((d: any) => { scores[d.label] = (window as any).apsGetDimScore(d.id); });
  const total = Object.values(scores).reduce((a: number, b: any) => a + (b as number), 0);
  const pct = Math.round((total / (DIMS.length * 9)) * 100);
  import("../utils/leadCapture").then(m => m.captureLead({
    email: result.email, name: result.name,
    tool: "AI Project Scoper", scores,
    verdict: `${pct}% readiness, ${plan?.tasks?.length ?? 0} tasks`,
  }));
  (window as any).apsExportXLSX();
};

(window as any).apsExportPDFWithDialog = async () => {
  const result = await showExportDialog("AI Project Scoper", "PDF");
  if (!result) return;
  const state = (window as any).apsGetState();
  const plan = (window as any).apsGetPlan();
  const DIMS = (window as any).apsGetDIMENSIONS();
  const DIM_COLORS: Record<string, string> = {
    data: "#0F6E56", model: "#185FA5", architecture: "#534AB7",
    governance: "#BA7517", team: "#993C1D", evaluation: "#2D6A4F",
  };
  const dimensions = DIMS.map((d: any) => {
    const score = (window as any).apsGetDimScore(d.id);
    return { label: d.label, score, maxScore: 9, level: (window as any).apsGetDimLevelLabel(score), color: DIM_COLORS[d.id] || "#555" };
  });
  const totalScore = dimensions.reduce((a: number, d: any) => a + d.score, 0);
  const overallPct = Math.round((totalScore / (DIMS.length * 9)) * 100);
  const scores: Record<string, number> = {};
  dimensions.forEach((d: any) => { scores[d.label] = d.score; });

  import("../utils/leadCapture").then(m => m.captureLead({
    email: result.email, name: result.name,
    tool: "AI Project Scoper", scores,
    verdict: `${overallPct}% readiness, ${plan?.tasks?.length ?? 0} tasks`,
  }));

  const qaItems: { question: string; answer: string; section?: string }[] = [];
  DIMS.forEach((d: any) => {
    d.questions.forEach((q: any, qi: number) => {
      const val = state.scores[d.id]?.[qi];
      const selectedOpt = q.opts.find((o: any) => o.v === val);
      qaItems.push({ question: q.text, answer: selectedOpt ? selectedOpt.l : "Not answered", section: d.label });
    });
  });
  const { generateScoperPDF } = await import("../utils/pdfReport");
  generateScoperPDF({
    projectName: state.profile.projectName || "Untitled",
    approach: state.profile.approach, domain: state.profile.domain || "",
    teamSize: state.profile.teamSize || "", timeline: state.profile.timeline || "",
    dimensions, overallPct,
    taskCount: plan?.tasks?.length ?? 0, riskCount: plan?.risks?.length ?? 0,
    topRisks: (plan?.risks ?? []).slice(0, 5).map((r: any) => ({ title: r.title, impact: r.impact, mitigation: r.mitigation })),
    qaItems,
  }).save(`AI-Scope-${(state.profile.projectName || "Project").replace(/\s+/g, "-")}.pdf`);
};
</script>
