  scale:{label:'Scale',emoji:'\u25C9',goal:'Grow & sustain',
    milestones:['Automated retraining or refresh pipeline active','Cost baseline established & optimised','Business impact measured & reported to sponsors','Continuous governance & evaluation in place']}
};

const TIMELINE_DURATIONS = {
  poc:{discovery:'1\u20132 wks',prototype:'2\u20134 wks',validate:'1\u20132 wks',deploy:'1\u20132 wks',scale:'\u2014'},
  mvp:{discovery:'2\u20133 wks',prototype:'4\u20136 wks',validate:'2\u20133 wks',deploy:'2\u20133 wks',scale:'3\u20135 wks'},
  production:{discovery:'3\u20134 wks',prototype:'5\u20138 wks',validate:'3\u20134 wks',deploy:'3\u20135 wks',scale:'6\u201310 wks'}
};

