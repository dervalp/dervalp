---
interface Props {
  approachFinderUrl?: string;
}
const { approachFinderUrl = '' } = Astro.props;
---

<div class="aps-root" id="aps-root" data-approach-finder-url={approachFinderUrl}>
  <div class="aps-step-indicator">
    <div class="aps-step-node">
      <div class="aps-step-circle active" id="aps-sc1">1</div>
      <span class="aps-step-label active" id="aps-sl1">Profile</span>
    </div>
    <div class="aps-step-connector" id="aps-conn1"></div>
    <div class="aps-step-node">
      <div class="aps-step-circle" id="aps-sc2">2</div>
      <span class="aps-step-label" id="aps-sl2">Dimensions</span>
    </div>
    <div class="aps-step-connector" id="aps-conn2"></div>
    <div class="aps-step-node">
      <div class="aps-step-circle" id="aps-sc3">3</div>
      <span class="aps-step-label" id="aps-sl3">Roadmap</span>
    </div>
  </div>

  <div class="aps-section visible" id="aps-step1"></div>
  <div class="aps-section" id="aps-step2"></div>
  <div class="aps-section" id="aps-step3"></div>
</div>

<style is:global>
.aps-root {
  --aps-bg:#FAF7F2;--aps-surface:#FFFFFF;--aps-border:#E6DDD3;--aps-border-hover:#C8B8A8;
  --aps-accent:#C8553A;--aps-accent-light:#D4714E;--aps-accent-bg:rgba(200,85,58,0.06);--aps-accent-border:rgba(200,85,58,0.22);
  --aps-text:#2D2520;--aps-text-strong:#1A1410;--aps-muted:#8A7D74;--aps-muted-light:#B0A69D;
  --aps-green:#4A7C59;--aps-green-bg:rgba(74,124,89,0.08);--aps-green-border:rgba(74,124,89,0.25);
  --aps-amber:#B5762A;--aps-amber-bg:rgba(181,118,42,0.08);--aps-amber-border:rgba(181,118,42,0.25);
  --aps-red:#C8553A;--aps-red-bg:rgba(200,85,58,0.08);--aps-red-border:rgba(200,85,58,0.25);
  --aps-shadow:0 1px 3px rgba(45,37,32,0.07),0 1px 2px rgba(45,37,32,0.04);
  --aps-shadow-hover:0 4px 14px rgba(45,37,32,0.09),0 2px 4px rgba(45,37,32,0.05);
  --aps-dim-data:#5E6B7C;--aps-dim-model:#C8553A;--aps-dim-architecture:#7C6340;
  --aps-dim-governance:#4A7C59;--aps-dim-team:#8B5E8B;--aps-dim-evaluation:#2D7D9A;

  font-family:'DM Sans',-apple-system,sans-serif;
  color:var(--aps-text);
  max-width:720px;
  margin:0 auto;
  -webkit-font-smoothing:antialiased;
}

/* ── STEP INDICATOR ── */
.aps-root .aps-step-indicator{display:flex;align-items:center;justify-content:center;gap:0;margin-bottom:48px}
.aps-root .aps-step-node{display:flex;flex-direction:column;align-items:center;gap:6px;position:relative;z-index:1}
.aps-root .aps-step-circle{width:32px;height:32px;border-radius:50%;border:2px solid var(--aps-border);background:var(--aps-surface);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--aps-muted);transition:all .3s ease}
.aps-root .aps-step-circle.active{border-color:var(--aps-accent);background:var(--aps-accent);color:#fff}
.aps-root .aps-step-circle.done{border-color:var(--aps-accent);background:var(--aps-accent-bg);color:var(--aps-accent)}
.aps-root .aps-step-label{font-size:11px;color:var(--aps-muted);font-weight:500;white-space:nowrap}
.aps-root .aps-step-label.active{color:var(--aps-accent);font-weight:600}
.aps-root .aps-step-connector{width:60px;height:2px;background:var(--aps-border);margin:0 4px;margin-bottom:22px;transition:background .3s}
.aps-root .aps-step-connector.done{background:var(--aps-accent)}

/* ── SECTIONS ── */
.aps-root .aps-section{display:none;animation:apsFadeUp .35s ease}
.aps-root .aps-section.visible{display:block}
@keyframes apsFadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── PROFILE FORM (STEP 1) ── */
.aps-root .field-group{margin-bottom:28px}
.aps-root .field-label{font-size:13px;font-weight:600;color:var(--aps-text-strong);margin-bottom:4px;display:block}
.aps-root .field-desc{font-size:12px;color:var(--aps-muted);margin-bottom:12px}
.aps-root .text-input{width:100%;padding:12px 16px;border:1.5px solid var(--aps-border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:15px;color:var(--aps-text);background:var(--aps-surface);outline:none;transition:border .2s}
.aps-root .text-input:focus{border-color:var(--aps-accent)}
.aps-root .option-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px}
.aps-root .option-card{padding:14px 16px;border:1.5px solid var(--aps-border);border-radius:10px;cursor:pointer;background:var(--aps-surface);transition:all .2s;text-align:left}
.aps-root .option-card:hover{border-color:var(--aps-border-hover);box-shadow:var(--aps-shadow-hover)}
.aps-root .option-card.selected{border-color:var(--aps-accent);background:var(--aps-accent-bg)}
.aps-root .option-card .opt-icon{font-size:18px;margin-bottom:6px;display:block}
.aps-root .option-card .opt-label{font-size:13px;font-weight:600;color:var(--aps-text-strong);display:block}
.aps-root .option-card .opt-desc{font-size:11px;color:var(--aps-muted);margin-top:2px;line-height:1.4}
.aps-root .option-card.selected .opt-label{color:var(--aps-accent)}

/* ── DIMENSION FORM (STEP 2) ── */
.aps-root .dim-header{margin-bottom:28px}
.aps-root .dim-progress{font-size:12px;color:var(--aps-muted);margin-bottom:6px;font-weight:500}
.aps-root .dim-title{font-family:'Newsreader',serif;font-size:22px;font-weight:600;color:var(--aps-text-strong);margin-bottom:4px}
.aps-root .dim-desc{font-size:14px;color:var(--aps-muted);line-height:1.5}
.aps-root .question-block{margin-bottom:24px;padding:20px;background:var(--aps-surface);border:1px solid var(--aps-border);border-radius:12px;box-shadow:var(--aps-shadow)}
.aps-root .question-text{font-size:14px;font-weight:600;color:var(--aps-text-strong);margin-bottom:14px;line-height:1.4}
.aps-root .radio-group{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.aps-root .radio-opt{padding:10px 12px;border:1.5px solid var(--aps-border);border-radius:8px;cursor:pointer;text-align:center;transition:all .2s}
.aps-root .radio-opt:hover{border-color:var(--aps-border-hover)}
.aps-root .radio-opt.selected{border-color:var(--aps-accent);background:var(--aps-accent-bg)}
.aps-root .radio-opt .ro-label{font-size:12px;color:var(--aps-text-strong);font-weight:600;line-height:1.3;display:block;margin-bottom:3px}
.aps-root .radio-opt.selected .ro-label{color:var(--aps-accent)}
.aps-root .radio-opt .ro-desc{font-size:11px;color:var(--aps-muted);line-height:1.35;display:block}
.aps-root .radio-opt.selected .ro-desc{color:var(--aps-accent-light);opacity:.85}

/* ── NAV BUTTONS ── */
.aps-root .nav-bar{display:flex;justify-content:space-between;align-items:center;margin-top:32px;gap:12px}
.aps-root .btn{padding:12px 24px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;border:none;display:inline-flex;align-items:center;gap:8px}
.aps-root .btn-primary{background:var(--aps-accent);color:#fff}
.aps-root .btn-primary:hover{background:var(--aps-accent-light);box-shadow:0 4px 12px rgba(200,85,58,.25)}
.aps-root .btn-primary:disabled{opacity:.4;cursor:not-allowed;box-shadow:none}
.aps-root .btn-secondary{background:var(--aps-surface);color:var(--aps-text);border:1.5px solid var(--aps-border)}
.aps-root .btn-secondary:hover{border-color:var(--aps-border-hover);background:#F5F0EB}
.aps-root .btn-export{background:var(--aps-text-strong);color:#fff;gap:8px}
.aps-root .btn-export:hover{background:#2D3748;box-shadow:0 4px 12px rgba(26,20,16,.3)}

/* ── RESULTS (STEP 3) ── */
.aps-root .scores-bar{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:32px}
@media(max-width:480px){.aps-root .scores-bar{grid-template-columns:repeat(2,1fr)}}
.aps-root .score-badge{padding:12px 14px;border-radius:10px;border:1px solid;background:var(--aps-surface)}
.aps-root .score-badge.good{border-color:var(--aps-green-border);background:var(--aps-green-bg)}
.aps-root .score-badge.attention{border-color:var(--aps-amber-border);background:var(--aps-amber-bg)}
.aps-root .score-badge.critical{border-color:var(--aps-red-border);background:var(--aps-red-bg)}
.aps-root .score-badge .sb-dim{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;opacity:.7;margin-bottom:4px}
.aps-root .score-badge .sb-score{font-family:'Newsreader',serif;font-size:22px;font-weight:600;line-height:1}
.aps-root .score-badge .sb-label{font-size:10px;font-weight:600;margin-top:2px}
.aps-root .score-badge.good .sb-score,.aps-root .score-badge.good .sb-label{color:var(--aps-green)}
.aps-root .score-badge.attention .sb-score,.aps-root .score-badge.attention .sb-label{color:var(--aps-amber)}
.aps-root .score-badge.critical .sb-score,.aps-root .score-badge.critical .sb-label{color:var(--aps-red)}

/* Tabs */
.aps-root .tabs{display:flex;gap:0;border-bottom:2px solid var(--aps-border);margin-bottom:28px}
.aps-root .tab{padding:10px 18px;font-size:13px;font-weight:600;color:var(--aps-muted);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .2s}
.aps-root .tab:hover{color:var(--aps-text)}
.aps-root .tab.active{color:var(--aps-accent);border-bottom-color:var(--aps-accent)}
.aps-root .tab-panel{display:none}
.aps-root .tab-panel.active{display:block;animation:apsFadeUp .25s ease}

/* Roadmap */
.aps-root .roadmap-grid{display:grid;grid-template-columns:1fr;gap:14px}
.aps-root .phase-card{background:var(--aps-surface);border:1px solid var(--aps-border);border-radius:12px;overflow:hidden;box-shadow:var(--aps-shadow)}
.aps-root .phase-header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--aps-border)}
.aps-root .phase-left{display:flex;align-items:center;gap:12px}
.aps-root .phase-num{width:28px;height:28px;border-radius:6px;background:var(--aps-accent);color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center}
.aps-root .phase-name{font-weight:700;font-size:15px;color:var(--aps-text-strong)}
.aps-root .phase-dur{font-size:12px;color:var(--aps-muted);font-weight:500}
.aps-root .phase-stats{display:flex;align-items:center;gap:10px}
.aps-root .phase-count{font-size:12px;color:var(--aps-muted);background:var(--aps-bg);padding:3px 10px;border-radius:99px;border:1px solid var(--aps-border)}
.aps-root .blocker-flag{font-size:11px;font-weight:700;color:var(--aps-red);background:var(--aps-red-bg);border:1px solid var(--aps-red-border);padding:3px 10px;border-radius:99px}
.aps-root .phase-body{padding:16px 18px;display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:520px){.aps-root .phase-body{grid-template-columns:1fr}}
.aps-root .milestone-list{list-style:none;padding:0;margin:0}
.aps-root .milestone-list li{font-size:12px;color:var(--aps-muted);padding:4px 0;padding-left:14px;position:relative;border-bottom:1px solid var(--aps-border);line-height:1.4}
.aps-root .milestone-list li:last-child{border-bottom:none}
.aps-root .milestone-list li::before{content:'\2192';position:absolute;left:0;color:var(--aps-accent);font-size:10px;top:5px}
.aps-root .phase-section-title{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--aps-muted);margin-bottom:8px}

/* Task List */
.aps-root .task-phase-group{margin-bottom:32px}
.aps-root .task-phase-title{font-family:'Newsreader',serif;font-size:17px;font-weight:600;color:var(--aps-text-strong);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--aps-border);display:flex;align-items:center;gap:10px}
.aps-root .phase-pill{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 10px;border-radius:99px}
.aps-root .phase-pill.discovery{background:#EBF3F7;color:#2D7D9A}
.aps-root .phase-pill.prototype{background:var(--aps-amber-bg);color:var(--aps-amber)}
.aps-root .phase-pill.validate{background:#EFF3EB;color:#4A7C59}
.aps-root .phase-pill.deploy{background:var(--aps-accent-bg);color:var(--aps-accent)}
.aps-root .phase-pill.scale{background:#F0EBF5;color:#8B5E8B}
.aps-root .task-table{width:100%;border-collapse:collapse;font-size:13px}
.aps-root .task-table th{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--aps-muted);padding:8px 10px;border-bottom:2px solid var(--aps-border);text-align:left;background:var(--aps-bg)}
.aps-root .task-table td{padding:10px 10px;border-bottom:1px solid var(--aps-border);vertical-align:top;line-height:1.4}
.aps-root .task-table tr:last-child td{border-bottom:none}
.aps-root .task-table tr:hover td{background:#FAF5EF}
.aps-root .dim-dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:5px;vertical-align:middle}
.aps-root .task-title-cell{color:var(--aps-text-strong);font-weight:500}
.aps-root .task-desc-cell{color:var(--aps-muted);font-size:12px;max-width:260px}
.aps-root .role-badge{font-size:11px;color:var(--aps-muted);white-space:nowrap}
.aps-root .size-badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700;background:var(--aps-bg);border:1px solid var(--aps-border);color:var(--aps-text)}
.aps-root .priority-badge{display:inline-block;padding:3px 8px;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;white-space:nowrap}
.aps-root .priority-badge.critical{background:var(--aps-red-bg);color:var(--aps-red);border:1px solid var(--aps-red-border)}
.aps-root .priority-badge.high{background:var(--aps-amber-bg);color:var(--aps-amber);border:1px solid var(--aps-amber-border)}
.aps-root .priority-badge.medium{background:#EDF2FF;color:#3B5BDB;border:1px solid rgba(59,91,219,.2)}
.aps-root .priority-badge.low{background:var(--aps-bg);color:var(--aps-muted);border:1px solid var(--aps-border)}

/* Risk Register */
.aps-root .risk-dim-group{margin-bottom:24px}
.aps-root .risk-dim-title{font-size:13px;font-weight:700;color:var(--aps-text-strong);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.aps-root .risk-card{padding:14px 16px;background:var(--aps-surface);border:1px solid var(--aps-border);border-radius:10px;margin-bottom:8px;box-shadow:var(--aps-shadow)}
.aps-root .risk-title{font-size:13px;font-weight:600;color:var(--aps-text-strong);margin-bottom:8px}
.aps-root .risk-meta{display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap}
.aps-root .risk-tag{font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;letter-spacing:.05em;text-transform:uppercase}
.aps-root .risk-tag.impact-high{background:var(--aps-red-bg);color:var(--aps-red);border:1px solid var(--aps-red-border)}
.aps-root .risk-tag.impact-medium{background:var(--aps-amber-bg);color:var(--aps-amber);border:1px solid var(--aps-amber-border)}
.aps-root .risk-tag.impact-low{background:var(--aps-green-bg);color:var(--aps-green);border:1px solid var(--aps-green-border)}
.aps-root .risk-tag.likelihood-high{background:var(--aps-red-bg);color:var(--aps-red);border:1px solid var(--aps-red-border)}
.aps-root .risk-tag.likelihood-medium{background:var(--aps-amber-bg);color:var(--aps-amber);border:1px solid var(--aps-amber-border)}
.aps-root .risk-mitigation{font-size:12px;color:var(--aps-muted);line-height:1.5;padding-top:8px;border-top:1px solid var(--aps-border)}
.aps-root .risk-mitigation strong{color:var(--aps-text)}

/* Export section */
.aps-root .export-bar{background:var(--aps-surface);border:1px solid var(--aps-border);border-radius:12px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;box-shadow:var(--aps-shadow)}
@media(max-width:520px){.aps-root .export-bar{flex-direction:column;gap:14px;text-align:center}}
.aps-root .export-info .ei-title{font-size:15px;font-weight:700;color:var(--aps-text-strong)}
.aps-root .export-info .ei-desc{font-size:12px;color:var(--aps-muted);margin-top:2px}
.aps-root .no-results{text-align:center;padding:48px 20px;color:var(--aps-muted);font-size:14px}
</style>

<script is:inline>
(function(){
// ═══════════════════════════════════════════════════════
// DATA: PROFILE QUESTIONS
// ═══════════════════════════════════════════════════════
const PROFILE_FIELDS = [
  {
    id:'approach', label:'AI Approach', desc:'What type of AI are you building?',
    options:[
      {value:'classic-ml',icon:'\u2699\uFE0F',label:'Classic ML',desc:'Regression, classification, clustering, time-series'},
      {value:'genai',icon:'\u2726',label:'Generative AI',desc:'Text generation, summarisation, content creation'},
      {value:'rag',icon:'\uD83D\uDD0D',label:'RAG',desc:'Retrieval-augmented generation on your own data'},
      {value:'agents',icon:'\u2B21',label:'AI Agents',desc:'Autonomous, multi-step, tool-using workflows'}
    ]
  },
  {
    id:'domain', label:'Domain', desc:'Your industry or primary use case area',
    options:[
      {value:'finance',icon:'\uD83D\uDCCA',label:'Finance',desc:'Risk, compliance, reporting, fraud'},
      {value:'healthcare',icon:'\uD83C\uDFE5',label:'Healthcare',desc:'Clinical, pharma, patient data'},
      {value:'retail',icon:'\uD83D\uDECD\uFE0F',label:'Retail / CPG',desc:'Demand, personalisation, supply chain'},
      {value:'manufacturing',icon:'\uD83C\uDFED',label:'Manufacturing',desc:'Quality, predictive maintenance, ops'},
      {value:'hr',icon:'\uD83D\uDC65',label:'HR / People',desc:'Talent, engagement, analytics'},
      {value:'other',icon:'\u25C6',label:'Other',desc:'SaaS, logistics, public sector, etc.'}
    ]
  },
  {
    id:'teamSize', label:'Team Size', desc:'People dedicated to this AI project',
    options:[
      {value:'solo',icon:'1',label:'Solo',desc:'1 person wearing all hats'},
      {value:'small',icon:'2\u20135',label:'Small team',desc:'2\u20135 people, some dedicated'},
      {value:'medium',icon:'5\u201315',label:'Medium team',desc:'5\u201315 people, clear roles'},
      {value:'large',icon:'15+',label:'Large team',desc:'15+ people, multiple workstreams'}
    ]
  },
  {
    id:'timeline', label:'Timeline Horizon', desc:'Target delivery milestone',
    options:[
      {value:'poc',icon:'\u26A1',label:'POC',desc:'Prove the concept in weeks'},
      {value:'mvp',icon:'\u25B8',label:'MVP',desc:'First production-ready version'},
      {value:'production',icon:'\u25C9',label:'Full production',desc:'Scaled, governed, enterprise-grade'}
    ]
  },
  {
    id:'budget', label:'Budget Tier', desc:'Investment level committed to this project',
    options:[
      {value:'experimental',icon:'\u25C7',label:'Experimental',desc:'Low, exploratory, time-boxed'},
      {value:'committed',icon:'\u25C6',label:'Committed',desc:'Funded programme with clear owner'},
      {value:'strategic',icon:'\u2605',label:'Strategic',desc:'Executive-sponsored, multi-year horizon'}
    ]
  }
];

// ═══════════════════════════════════════════════════════
// DATA: DIMENSION QUESTIONS
// ═══════════════════════════════════════════════════════
const DIMENSIONS = [
  {
    id:'data', label:'Data & Infrastructure', color:'var(--aps-dim-data)',
    desc:'Assess the availability, quality, and infrastructure readiness of your data.',
    questions:[
      {text:'How available and accessible is the data needed for this project?',
        opts:[{v:1,l:'Not yet available',d:'Needs to be collected or sourced'},{v:2,l:'Partially ready',d:'Some data exists, gaps remain'},{v:3,l:'Ready to use',d:'Data is accessible and structured'}]},
      {text:'What is the overall quality of your data?',
        opts:[{v:1,l:'Poor / unknown',d:'Noisy, incomplete, or unlabeled'},{v:2,l:'Mixed quality',d:'Usable but requires significant cleaning'},{v:3,l:'Clean & labeled',d:'Well-structured, trusted, and labeled'}]},
      {text:'How mature is your data infrastructure?',
        opts:[{v:1,l:'Greenfield',d:'No pipelines or storage in place'},{v:2,l:'Partial setup',d:'Some tooling exists, gaps to fill'},{v:3,l:'Production-ready',d:'Pipelines, storage, and access all set'}]}
    ]
  },
  {
    id:'model', label:'Model & AI Approach Fit', color:'var(--aps-dim-model)',
    desc:'Evaluate how well your chosen AI approach is validated and understood.',
    questions:[
      {text:'Has the chosen AI approach been validated for this specific use case?',
        opts:[{v:1,l:'No POC yet',d:'Purely hypothetical at this stage'},{v:2,l:'Similar POC done',d:'Validated in a related context'},{v:3,l:'Proven in context',d:'Direct proof of concept exists'}]},
      {text:'Do you have baseline models, benchmarks, or reference performance?',
        opts:[{v:1,l:'None',d:'Starting from scratch'},{v:2,l:'Partial',d:'Some benchmarks from research or vendors'},{v:3,l:'Well-defined',d:'Clear baseline and target metrics'}]},
      {text:'How frequently will the model need retraining or updating?',
        opts:[{v:1,l:'Continuously',d:'Real-time or weekly refresh needed'},{v:2,l:'Periodically',d:'Monthly or quarterly refresh'},{v:3,l:'Rarely',d:'Mostly static after initial training'}]}
    ]
  },
  {
    id:'architecture', label:'Architecture & Integration', color:'var(--aps-dim-architecture)',
    desc:'Understand the complexity of fitting AI into your existing systems.',
    questions:[
      {text:'How complex is the integration with your existing systems?',
