function apsUpdateStepUI(){
  [1,2,3].forEach(function(n){
    var c=document.getElementById('aps-sc'+n);
    var l=document.getElementById('aps-sl'+n);
    if(n<apsState.step){c.className='aps-step-circle done';c.innerHTML='\u2713'}
    else if(n===apsState.step){c.className='aps-step-circle active';c.textContent=n;l.className='aps-step-label active'}
    else{c.className='aps-step-circle';c.textContent=n;l.className='aps-step-label'}
  });
  [1,2].forEach(function(n){
    var conn=document.getElementById('aps-conn'+n);
    if(conn)conn.className='aps-step-connector'+(apsState.step>n?' done':'');
  });
}

function apsShowStep(n){
  apsState.step=n;
  document.querySelectorAll('#aps-root .aps-section').forEach(function(s){s.classList.remove('visible')});
  document.getElementById('aps-step'+n).classList.add('visible');
  apsUpdateStepUI();
}

