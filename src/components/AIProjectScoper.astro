// ═══════════════════════════════════════════════════════
// RULE ENGINE
// ═══════════════════════════════════════════════════════
function apsDimScore(d){return apsState.scores[d].reduce(function(a,b){return a+b},0)}
function apsDimLevel(s){return s<=4?'critical':s<=6?'attention':'good'}
function apsDimLevelLabel(s){return s<=4?'\u26A0 Blocker':s<=6?'Attention':'Good'}

var PRI_ORDER=['critical','high','medium','low'];
function apsBumpPriority(base,level){
  var i=PRI_ORDER.indexOf(base);
  if(level==='critical')return PRI_ORDER[Math.max(0,i-2)];
  if(level==='attention')return PRI_ORDER[Math.max(0,i-1)];
  return base;
}

function apsGeneratePlan(){
  var app=apsState.profile.approach;
  var tl=apsState.profile.timeline||'mvp';
  var tasks=TASKS.filter(function(t){return t.app==='all'||t.app.indexOf(app)!==-1});
  tasks=tasks.filter(function(t){
    if(!t.cond)return true;
    return apsDimScore(t.cond.dim)<=t.cond.maxScore;
  });
  tasks=tasks.map(function(t){
    var copy={};for(var k in t)copy[k]=t[k];
    copy.priority=apsBumpPriority(t.bp,apsDimLevel(apsDimScore(t.dim)));
    return copy;
  });
  var PH=['discovery','prototype','validate','deploy','scale'];
  tasks.sort(function(a,b){
    var pd=PH.indexOf(a.phase)-PH.indexOf(b.phase);
    if(pd!==0)return pd;
    return PRI_ORDER.indexOf(a.priority)-PRI_ORDER.indexOf(b.priority);
  });
  var durations=TIMELINE_DURATIONS[tl]||TIMELINE_DURATIONS.mvp;
  var phases=PH.map(function(ph){
    var pt=tasks.filter(function(t){return t.phase===ph});
    var crit=pt.filter(function(t){return t.priority==='critical'}).length;
    var high=pt.filter(function(t){return t.priority==='high'}).length;
    var m=PHASE_META[ph];
    return{id:ph,label:m.label,emoji:m.emoji,goal:m.goal,milestones:m.milestones,
      duration:durations[ph],tasks:pt,taskCount:pt.length,
      criticalCount:crit,highCount:high,hasBlocker:crit>0};
  });
  var risks=[];
  Object.keys(RISK_TEMPLATES).forEach(function(dim){
    var sc=apsDimScore(dim);
    if(sc<9){
      var lv=apsDimLevel(sc);
      var max=lv==='critical'?3:lv==='attention'?2:1;
      RISK_TEMPLATES[dim].slice(0,max).forEach(function(r){
        risks.push({dim:dim,impact:lv==='critical'?'High':'Medium',
          likelihood:sc<=4?'High':'Medium',title:r.title,mitigation:r.mitigation});
      });
    }
  });
  return{tasks:tasks,phases:phases,risks:risks};
}

