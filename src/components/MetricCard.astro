---
interface Props {
  value: string;
  label: string;
  detail: string;
}

const { value, label, detail } = Astro.props;
---

<div class="panel card-lift flex h-full flex-col justify-between p-6 sm:p-7">
  <div>
    <dt class="text-sm uppercase tracking-[0.22em] text-ink-500">Selected impact</dt>
    <dd class="mt-4 text-3xl font-semibold tracking-[-0.05em] text-ink-950 sm:text-4xl">
      {value}
    </dd>
  </div>
  <div class="mt-8 space-y-3">
    <p class="text-base font-medium leading-7 text-ink-900">{label}</p>
    <p class="text-sm leading-7 text-ink-600">{detail}</p>
  </div>
</div>

