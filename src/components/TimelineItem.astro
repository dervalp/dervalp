---
interface Props {
  role: string;
  company: string;
  context: string;
}

const { role, company, context } = Astro.props;
---

<li class="relative border-l border-[color:var(--line-strong)] pl-7">
  <span class="absolute left-[-0.34rem] top-2 h-3 w-3 rounded-full border border-[color:var(--line-strong)] bg-[color:var(--surface-strong)] shadow-[0_0_0_5px_rgba(244,241,235,1)]"></span>
  <p class="eyebrow !tracking-[0.18em]">{company}</p>
  <h3 class="mt-3 text-xl font-semibold tracking-[-0.03em] text-ink-950">{role}</h3>
  <p class="mt-3 max-w-2xl text-base leading-8 text-ink-600">{context}</p>
</li>

