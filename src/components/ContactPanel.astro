---
import IconLink from "./IconLink.astro";

interface Props {
  title: string;
  description: string;
  directMessage: string;
  secondaryMessage?: string;
  formTitle: string;
  formDescription: string;
  directTitle: string;
  directDescription: string;
  privacyNote?: string;
  unavailableMessage?: string;
  submitLabel: string;
  successMessage: string;
  errorMessage: string;
  endpoint: string;
  linkedinUrl: string;
  githubUrl: string;
  resumeHref: string;
}

const {
  title,
  description,
  directMessage,
  secondaryMessage,
  linkedinUrl,
  githubUrl,
  resumeHref
} = Astro.props;
---

<div class="contact-panel">
  <div>
    <p class="eyebrow">Contact</p>
    <h2 class="mt-4 max-w-3xl text-balance text-3xl font-semibold tracking-[-0.05em] text-ink-950 sm:text-4xl">
      {title}
    </h2>
    <p class="mt-6 max-w-2xl text-base leading-8 text-ink-600 sm:text-lg">
      {description}
    </p>
    <p class="mt-6 max-w-2xl text-base leading-8 text-ink-600 sm:text-lg">
      {directMessage}
    </p>
    {
      secondaryMessage && (
        <p class="mt-6 max-w-2xl text-base leading-8 text-ink-600 sm:text-lg">
          {secondaryMessage}
        </p>
      )
    }

    <div class="contact-panel__actions">
      <IconLink external={true} href={linkedinUrl} icon="linkedin" kind="button-secondary" label="LinkedIn" />
      <IconLink external={true} href={githubUrl} icon="github" kind="button-secondary" label="GitHub" />
      <IconLink href={resumeHref} icon="download" kind="button-secondary" label="Resume" />
    </div>
  </div>

  <div class="contact-panel__surface">
    <div
      class="calendly-inline-widget contact-panel__calendly"
      data-url="https://calendly.com/dervalp/30min?hide_event_type_details=1&hide_gdpr_banner=1&background_color=f3efe7&text_color=5c6871&primary_color=15191c"
      style="min-width:320px;height:480px;"
      role="region"
      aria-label="Book a call with Pierre Derval"
    ></div>
  </div>
</div>

<script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
