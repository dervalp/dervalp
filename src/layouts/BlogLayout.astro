---
import { siteData } from "../data/site";
import BaseLayout from "./BaseLayout.astro";
import HeaderNav from "../components/HeaderNav.astro";
import { absoluteUrl, withBase } from "../utils/url";

interface Props {
  title: string;
  description: string;
  isArticle?: boolean;
  publishDate?: Date;
  updatedDate?: Date;
  image?: string;
  imageAlt?: string;
  author?: string;
  category?: string;
}

const {
  title,
  description,
  isArticle = false,
  publishDate,
  updatedDate,
  image,
  author,
  category,
} = Astro.props;

const ogImageUrl = image ? absoluteUrl(image, Astro.site) : undefined;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    {isArticle && (
      <>
        <meta property="og:type" content="article" />
        {author && <meta property="article:author" content={author} />}
        {publishDate && (
          <meta
            property="article:published_time"
            content={publishDate.toISOString()}
          />
        )}
        {(updatedDate ?? publishDate) && (
          <meta
            property="article:modified_time"
            content={(updatedDate ?? publishDate)!.toISOString()}
          />
        )}
        {category && (
          <meta property="article:section" content={category} />
        )}
        {ogImageUrl && (
          <>
            <meta property="og:image" content={ogImageUrl} />
            <meta name="twitter:image" content={ogImageUrl} />
          </>
        )}
      </>
    )}
  </Fragment>

  <HeaderNav
    ctaHref="/contact"
    ctaLabel={siteData.hero.primaryCtaLabel}
    githubUrl={siteData.socials.githubUrl}
    linkedinUrl={siteData.socials.linkedinUrl}
    name={siteData.hero.name}
    sections={siteData.navigation}
  />

  <main id="main-content">
    <slot />
  </main>
</BaseLayout>
