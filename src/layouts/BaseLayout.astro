---
import "../styles/global.css";
import { siteData } from "../data/site";
import { absoluteUrl, withBase } from "../utils/url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteData.seo.title,
  description = siteData.seo.description
} = Astro.props;

const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : undefined;
const siteRootUrl = Astro.site
  ? new URL(import.meta.env.BASE_URL, Astro.site).toString()
  : undefined;
const ogImageUrl = absoluteUrl(siteData.seo.ogImage, Astro.site);
const faviconHref = withBase(siteData.seo.favicon);
const structuredData = siteRootUrl
  ? [
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": `${siteRootUrl}#website`,
        name: siteData.seo.siteName,
        url: siteRootUrl,
        description: siteData.seo.description,
        inLanguage: "en-BE"
      },
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": `${siteRootUrl}#person`,
        name: siteData.hero.name,
        url: siteRootUrl,
        description: siteData.seo.description,
        jobTitle: "AI product leadership for enterprise software",
        sameAs: [siteData.socials.linkedinUrl, siteData.socials.githubUrl],
        knowsAbout: [
          "AI product leadership",
          "Platform strategy",
          "Enterprise software",
          "Product leadership",
          "AI governance"
        ]
      }
    ]
  : undefined;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f3efe7" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (() => {
        const storageKey = "pierre-theme";
        const themeColors = {
          light: "#f3efe7",
          dark: "#11161a"
        };

        try {
          const savedTheme = window.localStorage.getItem(storageKey);
          const theme = savedTheme === "dark" || savedTheme === "light"
            ? savedTheme
            : "light";
          document.documentElement.dataset.theme = theme;
          const themeMeta = document.querySelector('meta[name="theme-color"]');
          themeMeta?.setAttribute("content", themeColors[theme]);
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-41795XWWS0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      gtag("js", new Date());
      gtag("config", "G-41795XWWS0");
    </script>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteData.seo.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={siteData.seo.locale} />
    <meta property="og:image" content={ogImageUrl} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <link rel="me" href={siteData.socials.linkedinUrl} />
    <link rel="me" href={siteData.socials.githubUrl} />
    {structuredData && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
      />
    )}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
