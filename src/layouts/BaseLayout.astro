---
import "../styles/global.css";
import { siteData } from "../data/site";
import { absoluteUrl, withBase } from "../utils/url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteData.seo.title,
  description = siteData.seo.description
} = Astro.props;

const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : undefined;
const ogImageUrl = absoluteUrl(siteData.seo.ogImage, Astro.site);
const faviconHref = withBase(siteData.seo.favicon);
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f4f1eb" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (() => {
        const storageKey = "pierre-theme";
        const fallbackTheme = "light";
        const themeColors = {
          light: "#f4f1eb",
          dark: "#0f1316"
        };

        try {
          const savedTheme = window.localStorage.getItem(storageKey);
          const theme = savedTheme === "dark" || savedTheme === "light"
            ? savedTheme
            : fallbackTheme;
          document.documentElement.dataset.theme = theme;
          const themeMeta = document.querySelector('meta[name="theme-color"]');
          themeMeta?.setAttribute("content", themeColors[theme]);
        } catch {
          document.documentElement.dataset.theme = fallbackTheme;
        }
      })();
    </script>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteData.seo.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={siteData.seo.locale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
